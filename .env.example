# Required
DISCORD_TOKEN=your_discord_bot_token
CLAUDE_CODE_OAUTH_TOKEN=your_claude_code_oauth_token

# Channel config: JSON array of channels the bot should respond in
# id: Discord channel ID
# name: folder name for the channel workspace
# mode: "full" (all tools) or "chat" (restricted)
# model: "opus", "sonnet", or "haiku" (default: sonnet)
CHANNEL_CONFIG='[{"id":"123456789","name":"general","mode":"full","model":"sonnet"}]'

# Optional
BOT_NAME=Bot
WENDY_PROXY_PORT=8945
CLAUDE_CLI_IDLE_TIMEOUT=300
CLAUDE_CLI_MAX_RUNTIME=1800
LOG_LEVEL=INFO
